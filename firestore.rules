rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAllowedCollectionDoc(docId) {
      return docId in ['chickens', 'eggs', 'feed', 'health', 'finances', 'incubation'];
    }

    function isValidCollectionPayload() {
      return request.resource.data.keys().hasOnly(['data', 'lastUpdated']) &&
        request.resource.data.data is list &&
        request.resource.data.lastUpdated is int;
    }

    // Vérifie qu'un worker appartient bien à cette ferme spécifique
    function belongsToFarm(farmId) {
      return isSignedIn() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)/settings/profile) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)/settings/profile).data.farmId == farmId;
    }

    // =========================================================
    // USER DATA
    // =========================================================
    match /users/{userId} {
      allow read, write: if false;

      match /collections/{docId} {
        allow read: if isOwner(userId) && isAllowedCollectionDoc(docId);
        allow create, update: if isOwner(userId) &&
          isAllowedCollectionDoc(docId) &&
          isValidCollectionPayload();
        allow delete: if isOwner(userId) && isAllowedCollectionDoc(docId);
      }

      match /settings/preferences {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isSignedIn();
        allow delete: if isOwner(userId);
      }

      match /settings/profile {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isSignedIn();
        allow delete: if isOwner(userId);
      }
    }

    // =========================================================
    // FARM DATA — accès strictement limité à la ferme concernée
    // =========================================================
    match /farms/{farmId} {
      allow read, write: if false;

      match /collections/{docId} {
        allow read: if isSignedIn() && isAllowedCollectionDoc(docId) && (
          request.auth.uid == farmId ||
          belongsToFarm(farmId)        // ← CORRIGÉ : vérifie le farmId du profil
        );
        allow create, update: if isSignedIn() && isAllowedCollectionDoc(docId) &&
          isValidCollectionPayload() && (
            request.auth.uid == farmId ||
            belongsToFarm(farmId)
          );
        allow delete: if isSignedIn() && isAllowedCollectionDoc(docId) &&
          request.auth.uid == farmId;
      }
    }

    // =========================================================
    // INVITATIONS
    // =========================================================
    match /invitations/{invitationId} {
      allow read: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        resource.data.senderId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (
        resource.data.email == request.auth.token.email ||
        resource.data.senderId == request.auth.uid
      );
      allow delete: if isSignedIn() && resource.data.senderId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
